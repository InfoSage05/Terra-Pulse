# ==========================================
# Database Configuration (Storage & Backend)
# ==========================================
DATABASE_URL=postgresql://terrapulse:password@postgres:5432/terrapulse
POSTGRES_USER=terrapulse
POSTGRES_PASSWORD=password
POSTGRES_DB=terrapulse

# ==========================================
# Redis Configuration (Backend Caching)
# ==========================================
REDIS_URL=redis://redis:6379/0

# ==========================================
# Backend Configuration
# ==========================================
MODEL_REGISTRY_PATH=/app/data/models
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Choose a free model (e.g. meta-llama/llama-3.3-70b-instruct:free, qwen/qwen-2.5-72b-instruct:free, google/gemma-2-9b-it:free)
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ==========================================
# Frontend Configuration
# ==========================================
VITE_API_BASE_URL=http://localhost:8000
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
