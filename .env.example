# ==========================================
# Database Configuration (Storage & Backend)
# ==========================================
DATABASE_URL=postgresql://terrapulse:password@postgres:5432/terrapulse
POSTGRES_USER=terrapulse
POSTGRES_PASSWORD=password
POSTGRES_DB=terrapulse

# ==========================================
# Redis Configuration (Backend Caching)
# ==========================================
REDIS_URL=redis://redis:6379/0

# ==========================================
# Backend Configuration
# ==========================================
MODEL_REGISTRY_PATH=/app/data/models
# X-API-Key header value(s). API_KEYS is optional and comma-separated, for
# rotating a key without downtime (add the new one here, deploy, then
# remove the old one) - both API_KEY and every entry in API_KEYS are valid.
# This is a shared-secret placeholder, not a real per-client auth system.
API_KEY=dev_secret_key
API_KEYS=
# Comma-separated list of origins allowed by CORS.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
OPENROUTER_API_KEY=your_openrouter_api_key_here 
# Choose a free model (e.g. meta-llama/llama-3.3-70b-instruct:free, qwen/qwen-2.5-72b-instruct:free, google/gemma-2-9b-it:free)
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Groq has its own separate free-tier quota (not shared with OpenRouter's
# congested free-model pool), so LLMClient tries Groq first when this is
# set, falling back to the OpenRouter model list above only if Groq fails.
GROQ_API_KEY=your_groq_api_key_here

# ==========================================
# Frontend Configuration
# ==========================================
VITE_API_BASE_URL=http://localhost:8000/v1
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
