# ==========================================
# Backend Configuration
# ==========================================
MODEL_REGISTRY_PATH=/app/data/models
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ==========================================
# Frontend Configuration
# ==========================================
VITE_API_BASE_URL=http://localhost:8000
